{
  "schema": 1,
  "name": "generic-agent-tool-comparison",
  "baseline": "baseline_no_user_config",
  "agent": "${TOKENSMASH_AGENT:-codex}",
  "model": "${TOKENSMASH_MODEL:-gpt-5.5}",
  "claude_model": "${TOKENSMASH_CLAUDE_MODEL:-sonnet}",
  "reasoning": "${TOKENSMASH_REASONING:-low}",
  "claude_effort": "${TOKENSMASH_CLAUDE_EFFORT:-low}",
  "claude_max_budget_usd": "${TOKENSMASH_MAX_BUDGET_USD:-}",
  "sandbox": "workspace-write",
  "replicates": 1,
  "timeout_seconds": 1800,
  "tasks": [
    {
      "id": "target-repo-task",
      "repo": "${TARGET_REPO}",
      "base_ref": "${TARGET_BASE_REF:-HEAD}",
      "prompt": "${TARGET_PROMPT}",
      "success_commands": [
        "${TARGET_TEST_COMMAND}"
      ],
      "success_timeout_seconds": 300
    }
  ],
  "variants": [
    {
      "id": "baseline_no_user_config",
      "label": "Baseline: no user config, MCP, hooks, or repo rules",
      "requires": {
        "env": [
          "TARGET_REPO",
          "TARGET_PROMPT",
          "TARGET_TEST_COMMAND"
        ]
      },
      "codex_args": [
        "--ignore-user-config",
        "--ignore-rules"
      ],
      "claude_args": [
        "--safe-mode"
      ]
    },
    {
      "id": "context_mode",
      "label": "context-mode MCP plus lifecycle hooks",
      "codex_home": true,
      "codex_config": "[features]\nhooks = true\n\n[mcp_servers.context-mode]\ncommand = \"context-mode\"\n[mcp_servers.context-mode.env]\nCONTEXT_MODE_PLATFORM = \"codex\"",
      "codex_hooks": "context-mode",
      "codex_args": [
        "--ignore-rules",
        "--dangerously-bypass-hook-trust"
      ],
      "claude_mcp_config": {
        "mcpServers": {
          "context-mode": {
            "command": "context-mode",
            "env": {
              "CONTEXT_MODE_PLATFORM": "claude-code"
            }
          }
        }
      },
      "claude_settings": {
        "hooks": {
          "PreToolUse": [
            {
              "matcher": "Bash|Read|Grep|WebFetch|Agent|mcp__",
              "hooks": [
                {
                  "type": "command",
                  "command": "context-mode hook claude-code pretooluse"
                }
              ]
            }
          ],
          "PostToolUse": [
            {
              "matcher": "Bash|Read|Write|Edit|Glob|Grep|TodoWrite|Agent|mcp__",
              "hooks": [
                {
                  "type": "command",
                  "command": "context-mode hook claude-code posttooluse"
                }
              ]
            }
          ],
          "SessionStart": [
            {
              "matcher": "",
              "hooks": [
                {
                  "type": "command",
                  "command": "context-mode hook claude-code sessionstart"
                }
              ]
            }
          ],
          "PreCompact": [
            {
              "matcher": "",
              "hooks": [
                {
                  "type": "command",
                  "command": "context-mode hook claude-code precompact"
                }
              ]
            }
          ],
          "UserPromptSubmit": [
            {
              "matcher": "",
              "hooks": [
                {
                  "type": "command",
                  "command": "context-mode hook claude-code userpromptsubmit"
                }
              ]
            }
          ]
        }
      },
      "prompt_prefix": "Use context-mode sandbox/MCP tools for repository discovery, broad search, web fetches, and large command outputs. Return only concise derived answers to the chat.",
      "requires": {
        "env": [
          "TARGET_REPO",
          "TARGET_PROMPT",
          "TARGET_TEST_COMMAND"
        ],
        "commands": [
          "context-mode"
        ]
      }
    },
    {
      "id": "headroom",
      "label": "Headroom wrap proxy for automatic request compression",
      "codex_home": true,
      "codex_wrapper": [
        "headroom",
        "wrap",
        "codex",
        "--no-serena"
      ],
      "claude_wrapper": [
        "headroom",
        "wrap",
        "claude",
        "--no-serena"
      ],
      "requires": {
        "env": [
          "TARGET_REPO",
          "TARGET_PROMPT",
          "TARGET_TEST_COMMAND"
        ],
        "commands": [
          "headroom"
        ]
      }
    },
    {
      "id": "rtk",
      "label": "RTK Claude hook or Codex AGENTS/RTK instructions",
      "codex_home": true,
      "codex_home_files": {
        "AGENTS.md": "@RTK.md",
        "RTK.md": "# RTK - Rust Token Killer (Codex CLI)\n\nAlways prefix shell commands with `rtk --ultra-compact` when the wrapper preserves command semantics. Prefer `rtk git`, `rtk grep`, `rtk find`, `rtk go test`, `rtk npm`, `rtk pytest`, and `rtk test` over raw high-output commands.\n\nUse `rtk proxy <cmd>` only when full raw output is required."
      },
      "codex_prompt_prefix": "RTK is installed. Follow the RTK.md rule from the isolated Codex home: prefer `rtk --ultra-compact` wrappers for shell commands whenever semantics are preserved.",
      "claude_settings": {
        "hooks": {
          "PreToolUse": [
            {
              "matcher": "Bash",
              "hooks": [
                {
                  "type": "command",
                  "command": "rtk hook claude --ultra-compact"
                }
              ]
            }
          ]
        }
      },
      "claude_prompt_prefix": "RTK's Claude hook rewrites Bash commands only. Prefer Bash/shell commands over built-in Read/Grep/Glob when that preserves correctness, so RTK can compact the output.",
      "requires": {
        "env": [
          "TARGET_REPO",
          "TARGET_PROMPT",
          "TARGET_TEST_COMMAND"
        ],
        "commands": [
          "rtk"
        ]
      }
    },
    {
      "id": "semmap",
      "label": "SEMMAP chat map before source reads",
      "requires": {
        "env": [
          "TARGET_REPO",
          "TARGET_PROMPT",
          "TARGET_TEST_COMMAND",
          "SEMMAP_BIN"
        ]
      },
      "setup_commands": [
        "\"$SEMMAP_BIN\" generate --root \"{repo_dir}\" --chat-output \"{run_dir}/SEMMAP.md\" || \"$SEMMAP_BIN\" generate --root \"{repo_dir}\" --output \"{run_dir}/SEMMAP.md\""
      ],
      "codex_args": [
        "--ignore-user-config",
        "--ignore-rules"
      ],
      "prompt_prefix": "Before searching broadly or reading source files, inspect {run_dir}/SEMMAP.md, identify a minimal working set, and then read only the files needed for the task. If the installed SEMMAP supports trace/cat commands, use them to narrow the working set."
    },
    {
      "id": "repomix",
      "label": "Repomix MCP incremental repository packing",
      "codex_home": true,
      "codex_config": "[mcp_servers.repomix]\ncommand = \"npx\"\nargs = [\"--yes\", \"repomix@latest\", \"--mcp\"]",
      "claude_mcp_config": {
        "mcpServers": {
          "repomix": {
            "command": "npx",
            "args": [
              "--yes",
              "repomix@latest",
              "--mcp"
            ]
          }
        }
      },
      "prompt_prefix": "Use Repomix MCP incrementally: pack only task-relevant paths with focused include/ignore patterns, then grep or retrieve slices from the packed output. Do not read a full-repo pack into chat unless the task truly requires it.",
      "requires": {
        "env": [
          "TARGET_REPO",
          "TARGET_PROMPT",
          "TARGET_TEST_COMMAND"
        ],
        "commands": [
          "npx"
        ]
      }
    },
    {
      "id": "gitingest",
      "label": "Gitingest focused digest from explicit include patterns",
      "requires": {
        "env": [
          "TARGET_REPO",
          "TARGET_PROMPT",
          "TARGET_TEST_COMMAND",
          "TARGET_CONTEXT_INCLUDE"
        ],
        "commands": [
          "uvx"
        ]
      },
      "setup_commands": [
        "if [ -n \"$TARGET_CONTEXT_EXCLUDE\" ]; then uvx gitingest \"{repo_dir}\" --include-pattern \"$TARGET_CONTEXT_INCLUDE\" --exclude-pattern \"$TARGET_CONTEXT_EXCLUDE\" -o \"{run_dir}/gitingest.txt\"; else uvx gitingest \"{repo_dir}\" --include-pattern \"$TARGET_CONTEXT_INCLUDE\" -o \"{run_dir}/gitingest.txt\"; fi"
      ],
      "codex_args": [
        "--ignore-user-config",
        "--ignore-rules"
      ],
      "prompt_prefix": "A focused Gitingest digest is available at {run_dir}/gitingest.txt. Use it as the orientation artifact before reading source files, and then inspect only the minimal source files needed for the task."
    }
  ]
}
